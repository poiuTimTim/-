    console.error("API \uc0\u35531 \u27714 \u22833 \u25943 :", err);\
    \
    // \uc0\u55357 \u56481  \u24050 \u32147 \u31227 \u38500  localStorage.removeItem(...)\u65292 \u23601 \u31639 \u36935 \u21040 \u32178 \u36335 \u24310 \u36978 \u20063 \u19981 \u26371 \u20877 \u25226 \u37329 \u38000 \u21034 \u25481 \u20102 \
    \
    ocrBox.innerHTML = `\
      <div class="ocr-empty" style="color:var(--red); line-height: 1.6;">\
        \uc0\u9888 \u65039  <b>AI \u36776 \u35672 \u30332 \u29983 \u37679 \u35492 \u65281 </b><br><br>\
        \uc0\u21487 \u33021 \u21407 \u22240 \u22914 \u19979 \u65306 <br>\
        1. <b>\uc0\u20813 \u36027 \u38989 \u24230 \u38480 \u21046 </b>\u65306 \u35531 \u31245 \u31561  10 \u31186 \u24460 \u20877 \u35430 \u19968 \u27425 \u12290 <br>\
        2. <b>\uc0\u37329 \u38000 \u24050 \u22833 \u25928 </b>\u65306 \u22914 \u26524 \u31561 \u24453 \u24460 \u20173 \u28961 \u27861 \u20351 \u29992 \u65292 \u20195 \u34920 \u27492 \u37329 \u38000 \u24050 \u34987  Google \u23448 \u26041 \u20316 \u24290 \u65292 \u35531 \u25563 \u19968 \u25226 \u26032 \u37329 \u38000 \u12290 <br>\
      </div>`;\
    return \{ text: "", analysis: "", isCorrect: "", feedback: "" \};\
  \}\
\}\
\
function showCorrectionOnCanvas(text) \{\
  const overlay = document.getElementById('correctionOverlay');\
  const container = document.getElementById('canvas-hw-container');\
  container.innerHTML = ''; overlay.classList.add('active');\
  const chars = text.match(/[\\u4e00-\\u9fa5]/g) || [];\
  if (chars.length === 0) \{\
    container.innerHTML = "<span style='font-size:13px;color:#dc2626;'>\uc0\u65288 \u28961 \u27861 \u25552 \u20379 \u27492 \u25991 \u23383 \u30340 \u21205 \u30059 \u31034 \u31684 \u65289 </span>";\
  \} else \{\
    chars.forEach(char => \{\
      const subDiv = document.createElement('div');\
      subDiv.id = 'hw-canvas-' + Math.random().toString(36).substr(2, 9);\
      container.appendChild(subDiv);\
      try \{\
        let writer = HanziWriter.create(subDiv.id, char, \{\
          width: 110, height: 110, padding: 5, showOutline: true, strokeAnimationSpeed: 1.2,\
          delayBetweenStrokes: 150, delayBetweenLoops: 2000, strokeColor: '#dc2626', radicalColor: '#16a34a'\
        \});\
        writer.loopCharacterAnimation();\
      \} catch (e) \{ console.error("HanziWriter \uc0\u28210 \u26579 \u22833 \u25943 ", e); \}\
    \});\
  \}\
  document.getElementById('writeCard').scrollIntoView(\{ behavior: 'smooth', block: 'center' \});\
\}\
\
function analyzeEmotion(speeds, pArr) \{\
  const box = document.getElementById('emotionContent');\
  box.innerHTML = '<div class="loading-state"><div class="spinner"></div><span>\uc0\u24773 \u32210 \u20998 \u26512 \u20013 ...</span></div>';\
\
  const avgP   = avg(pArr); const maxP   = Math.max(...pArr); const stdP   = std(pArr);\
  const avgSpd = speeds.length ? avg(speeds) : 0; const stdSpd = speeds.length ? std(speeds) : 0;\
  const pauseRatio = speeds.length ? speeds.filter(s=>s<2).length / speeds.length : 0;\
\
  const tension = clamp(avgP*0.45 + stdP*1.1 + (avgSpd/300)*0.35 + stdSpd/300*0.2);\
  const calm    = clamp((1-stdP*1.8)*0.4 + (1-stdSpd/200)*0.35 + pauseRatio*0.25);\
  const anger   = clamp(maxP*0.4 + (avgSpd/300)*0.3 + stdSpd/200*0.3);\
  const sadness = clamp((1-avgSpd/300)*0.4 + pauseRatio*0.35 + (1-avgP)*0.25);\
  const joy     = clamp((1-Math.abs(avgP-0.45)*2)*0.35 + (1-stdSpd/200)*0.35 + (1-pauseRatio)*0.3);\
\
  const scores = \{tension, calm, anger, sadness, joy\};\
  const defs = \{\
    tension: \{ name:'\uc0\u32202 \u24373  / \u23560 \u27880 ', icon:'\u55357 \u56868 ', color:'#f97316', desc:'\u21147 \u36947 \u36215 \u20239 \u26126 \u39023 \u19988 \u36895 \u24230 \u20559 \u24555 \u65292 \u39023 \u31034 \u30070 \u19979 \u34389 \u26044 \u32202 \u32323 \u25110 \u39640 \u24230 \u23560 \u27880 \u12290 ' \},\
    calm:    \{ name:'\uc0\u24179 \u38748  / \u31337 \u23450 ', icon:'\u55357 \u56844 ', color:'#22c55e', desc:'\u31558 \u22739 \u24179 \u31337 \u12289 \u36895 \u24230 \u22343 \u21243 \u65292 \u20572 \u38931 \u33258 \u28982 \u65292 \u39023 \u31034 \u24773 \u32210 \u31337 \u23450 \u24605 \u32210 \u28165 \u26224 \u12290 ' \},\
    anger:   \{ name:'\uc0\u28608 \u21205  / \u24613 \u36843 ', icon:'\u55357 \u56864 ', color:'#ef4444', desc:'\u20597 \u28204 \u21040 \u26997 \u39640 \u31558 \u22739 \u19988 \u19981 \u35215 \u24459 \u65292 \u26360 \u23531 \u21205 \u20316 \u24375 \u28872 \u65292 \u39023 \u31034 \u21487 \u33021 \u36611 \u28858 \u24613 \u36843 \u12290 ' \},\
    sadness: \{ name:'\uc0\u30130 \u20518  / \u20302 \u33853 ', icon:'\u55357 \u56852 ', color:'#6366f1', desc:'\u36895 \u24230 \u32233 \u24930 \u12289 \u20572 \u38931 \u36611 \u22810 \u19988 \u31558 \u22739 \u36629 \u65292 \u39023 \u31034 \u21487 \u33021 \u30070 \u19979 \u36523 \u24515 \u36611 \u28858 \u30130 \u20518 \u12290 ' \},\
    joy:     \{ name:'\uc0\u36629 \u39686  / \u24841 \u24555 ', icon:'\u55357 \u56842 ', color:'#eab308', desc:'\u31680 \u22863 \u27969 \u26274 \u33258 \u28982 \u12289 \u31558 \u22739 \u36969 \u20013 \u65292 \u26360 \u23531 \u29376 \u24907 \u36629 \u39686 \u65292 \u24773 \u32210 \u21576 \u29694 \u27491 \u21521 \u12290 ' \},\
  \};\
\
  const topKey = Object.keys(scores).reduce((a,b) => scores[a]>scores[b]?a:b);\
  const top = defs[topKey];\
\
  const bars = Object.entries(defs).map(([k,v]) => \{\
    const pct = Math.round(scores[k]*100);\
    return `<div class="ebar">\
      <span class="ebar-name">$\{v.icon\} $\{v.name.split(' ')[0]\}</span>\
      <div class="ebar-track"><div class="ebar-fill" style="width:0%;background:$\{v.color\}" data-w="$\{pct\}%"></div></div>\
      <span class="ebar-val">$\{pct\}%</span>\
    </div>`;\
  \}).join('');\
\
  box.innerHTML = `\
    <div class="emotion-layout">\
      <div class="emotion-icon">$\{top.icon\}</div>\
      <div class="emotion-body">\
        <div class="emotion-name" style="color:$\{top.color\}">$\{top.name\}</div>\
        <div class="emotion-desc">$\{top.desc\}</div>\
        $\{bars\}\
      </div>\
    </div>`;\
\
  setTimeout(() => \{ box.querySelectorAll('.ebar-fill').forEach(el => \{ el.style.width = el.dataset.w; \}); \}, 80);\
\
  return \{\
    primary: top.name,\
    tension: Math.round(scores.tension*100), calm: Math.round(scores.calm*100),\
    anger: Math.round(scores.anger*100), sadness: Math.round(scores.sadness*100), joy: Math.round(scores.joy*100)\
  \};\
\}\
\
// \uc0\u55357 \u56481  3. \u20445 \u30041 \u39640 \u30456 \u23481 \u24615 \u30340  mode: 'no-cors' \u20786 \u23384 \u26550 \u27083 \u65292 \u30906 \u20445 \u26368 \u26032 \u32178 \u22336 \u20063 \u33021 \u30450 \u30332 \u25104 \u21151 \
function saveToSheet(n, avgP, maxP, avgS, emoData, ocrData) \{\
  const msg = document.getElementById('saveMsg');\
  msg.className = 'save-msg'; msg.textContent = '\uc0\u20786 \u23384 \u20013 ...';\
  \
  const payload = \{\
    session: 'session_' + Date.now(),\
    pointsCount: n, avgPressure: avgP, maxPressure: maxP, avgSpeed: avgS,\
    ocrText: ocrData.text, ocrAnalysis: ocrData.analysis, strokeCorrect: ocrData.isCorrect, strokeFeedback: ocrData.feedback,\
    primaryEmotion: emoData.primary, tension: emoData.tension, calm: emoData.calm, anger: emoData.anger, sadness: emoData.sadness, joy: emoData.joy,\
    points: getAllPoints()\
  \};\
\
  fetch(GAS_URL, \{\
    method:'POST', mode:'no-cors',\
    headers:\{'Content-Type':'application/json'\},\
    body: JSON.stringify(payload)\
  \}).then(()=>\{\
    msg.className='save-msg ok'; msg.textContent='\uc0\u10003  \u38642 \u31471 \u36039 \u26009 \u24050 \u21516 \u27493 ';\
    document.getElementById('sheetLink').style.display='inline';\
  \}).catch(()=>\{\
    msg.className='save-msg err'; msg.textContent='\uc0\u10007  \u20786 \u23384 \u22833 \u25943 \u65292 \u35531 \u19979 \u36617  CSV \u20633 \u29992 ';\
  \});\
\}\
\
function downloadCSV() \{\
  const pts = getAllPoints();\
  if (!pts.length) return;\
  const blob = new Blob(['x,y,t,pressure,tiltX,tiltY,type\\\\n' +\
    pts.map(p=>`$\{p.x\},$\{p.y\},$\{p.t\},$\{p.pressure\},$\{p.tiltX\},$\{p.tiltY\},$\{p.type\}`).join('\\\\n')],\
    \{type:'text/csv;charset=utf-8;'\});\
  const a = document.createElement('a');\
  a.href = URL.createObjectURL(blob);\
  a.download = 'stylus_'+Date.now()+'.csv'; a.click();\
\}\
\
function avg(a)      \{ return a.reduce((s,v)=>s+v,0)/a.length; \}\
function std(a)      \{ const m=avg(a); return Math.sqrt(avg(a.map(v=>(v-m)**2))); \}\
function clamp(v)    \{ return Math.max(0,Math.min(1,v)); \}\
</script>\
